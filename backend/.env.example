PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/smart_city_complaints
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Cloudinary complaint proof image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional first-admin seed values used by npm run seed:admin
# On Render free plan, these are also used automatically when the backend starts.
ADMIN_NAME=Smart City Admin
ADMIN_EMAIL=admin@example.com
ADMIN_MOBILE=9876543210
ADMIN_PASSWORD=Admin@12345
